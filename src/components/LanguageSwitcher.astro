---
/**
 * Per-page language switcher (dropdown).
 *
 * Only renders if the current document has a Ukrainian translation.
 * Selecting a language navigates to the English URL or `?lang=uk`.
 */
interface Props {
  productVersion: string;
  slug: string;
  hasUkTranslation: boolean;
  activeLang: 'en' | 'uk';
}

const { productVersion, slug, hasUkTranslation, activeLang } = Astro.props;

const enUrl = `/${productVersion}/${slug}/`;
const ukUrl = `/${productVersion}/${slug}/?lang=uk`;
---

{hasUkTranslation && (
  <select
    class="opuscor-lang-select"
    aria-label="Select language"
    onchange="window.location.href = this.value;"
  >
    <option value={enUrl} selected={activeLang === 'en'}>EN</option>
    <option value={ukUrl} selected={activeLang === 'uk'}>UK</option>
  </select>
)}
