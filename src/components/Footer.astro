---
import linkedinIcon from '../assets/icons/linkedin.svg?raw';
import emailIcon from '../assets/icons/email.svg?raw';
import telegramIcon from '../assets/icons/telegram.svg?raw';
---

<footer class="opuscor-global-footer">
  <div class="footer-content">
    <p>SQL Cor Docs / Opuscor / Made with <span class="heart">♥︎</span></p>
    <div class="social-links">
      <a href="https://www.linkedin.com/in/koliada-artem/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" set:html={linkedinIcon} />
      <a href="mailto:artem@opuscor.com" aria-label="Email" set:html={emailIcon} />
      <a href="https://t.me/OpusCor" target="_blank" rel="noopener noreferrer" aria-label="Telegram" set:html={telegramIcon} />
    </div>
  </div>
</footer>

<style>
  .opuscor-global-footer {
    padding: var(--opuscor-s-8);
    text-align: center;
    border-top: 1px solid var(--opuscor-bdr);
    margin-top: var(--opuscor-s-10);
  }
  .heart {
    display: inline-block;
    color: var(--opuscor-accent);
    margin: 0 0.5rem;
    animation: beat 3s ease-in-out infinite;
  }
  .social-links {
    margin-top: var(--opuscor-s-4);
    display: flex;
    gap: var(--opuscor-s-5);
    justify-content: center;
  }
  .social-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }
  .social-links :global(svg) {
    width: 20px;
    height: 20px;
    fill: var(--opuscor-muted);
    transition: 0.3s;
  }
  .social-links a:hover :global(svg) {
    fill: var(--opuscor-accent);
    filter: drop-shadow(0 0 8px var(--opuscor-accent));
  }
  @keyframes beat {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.3); }
  }
</style>
