---
import Pagination from '@astrojs/starlight/components/Pagination.astro';
import linkedinIcon from '../assets/icons/linkedin.svg?raw';
import emailIcon from '../assets/icons/email.svg?raw';
import telegramIcon from '../assets/icons/telegram.svg?raw';
---

<div class="opuscor-doc-pagination">
  <Pagination />
</div>

<footer class="opuscor-global-footer">
  <div class="footer-content">
    <p>SQL Cor Docs / Opuscor / Made with <span class="dn-heart">♥︎</span></p>
    <div class="social-links">
      <a href="https://www.linkedin.com/in/koliada-artem/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" set:html={linkedinIcon} />
      <a href="mailto:artem@opuscor.com" aria-label="Email" set:html={emailIcon} />
      <a href="https://t.me/OpusCor" target="_blank" rel="noopener noreferrer" aria-label="Telegram" set:html={telegramIcon} />
    </div>
  </div>
</footer>

<style>
  .opuscor-global-footer {
    padding: var(--opuscor-s-8);
    text-align: center;
    border-top: 1px solid var(--opuscor-bdr);
    margin-top: var(--opuscor-s-10);
    color: var(--opuscor-muted);
    font-size: var(--opuscor-fz-sm);
  }
  .social-links {
    margin-top: var(--opuscor-s-4);
    display: flex;
    gap: var(--opuscor-s-5);
    justify-content: center;
  }

  .social-links a {
    display: inline-flex;
    transition: 0.3s;
    color: var(--opuscor-muted) !important;
  }

  .social-links a:visited,
  .social-links a:active {
    color: var(--opuscor-muted) !important;
  }

  .social-links :global(svg) {
    width: 24px !important;
    height: 24px !important;
    fill: var(--opuscor-muted) !important;
    transition: 0.3s;
  }

  .social-links :global(svg path) {
    fill: var(--opuscor-muted) !important;
  }

  .social-links a:visited :global(svg),
  .social-links a:visited :global(svg path),
  .social-links a:active :global(svg),
  .social-links a:active :global(svg path) {
    fill: var(--opuscor-muted) !important;
  }

  .social-links a:hover :global(svg),
  .social-links a:hover :global(svg path) {
    fill: var(--opuscor-accent) !important;
    filter: drop-shadow(0 0 8px var(--opuscor-accent));
  }

</style>
