---
/**
 * Custom <head> override for Starlight.
 *
 * Wraps Starlight's default Head component and prepends Google Fonts
 * preconnect + stylesheet links for Inter and JetBrains Mono.
 *
 * Reference: https://starlight.astro.build/guides/overriding-components/
 */
import Default from '@astrojs/starlight/components/Head.astro';
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
/>

<Default />
