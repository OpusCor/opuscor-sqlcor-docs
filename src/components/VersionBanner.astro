---
/**
 * Banner shown on documents served under a non-latest product version.
 *
 * For Phase 2, only `v1.0` exists, so this never renders. It activates
 * when Phase 3 introduces v2.0 / v3.0 and users navigate to an older
 * version's documents.
 *
 * Styles live in src/styles/global.css under .opuscor-banner.
 */
import { LATEST_VERSION } from '../lib/product-versions';

interface Props {
  productVersion: string;
  slug: string;
}

const { productVersion, slug } = Astro.props;
const isOlder = productVersion !== LATEST_VERSION.id;
const latestUrl = `/${LATEST_VERSION.id}/${slug}/`;
---

{isOlder && (
  <aside class="opuscor-banner" role="status">
    <span class="opuscor-banner-icon">⌖</span>
    <div class="opuscor-banner-text">
      You are viewing docs for SQL Cor <b>{productVersion}</b>.
      The latest version is <b>{LATEST_VERSION.label}</b>.
    </div>
    <a class="opuscor-banner-link" href={latestUrl}>
      View this page in the latest version →
    </a>
  </aside>
)}
