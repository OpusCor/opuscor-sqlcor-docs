---
/**
 * Dynamic document router (Phase 2 — integrated with Starlight layout).
 *
 * Same resolution algorithm as Phase 0 (ARCHITECTURE.md §4), but the
 * output now uses Starlight's <StarlightPage> component so each
 * document gets the full layout: top nav, sidebar, search button,
 * theme toggle, right-rail TOC, breadcrumbs, mobile drawer.
 */
import { PRODUCT_VERSIONS } from '../../lib/product-versions';
import { listAllDocs } from '../../lib/doc-loader';
import { resolveDocumentVersion } from '../../lib/version-resolver';
import { buildEntryId, getSqlcorEntry } from '../../lib/get-doc-content';
import { render } from 'astro:content';

import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import DocFooter from '../../components/DocFooter.astro';
import LanguageSwitcher from '../../components/LanguageSwitcher.astro';
import VersionBanner from '../../components/VersionBanner.astro';

export async function getStaticPaths() {
  const docs = listAllDocs();
  const paths = [];

  for (const product of PRODUCT_VERSIONS) {
    for (const doc of docs) {
      const resolvedVersion = resolveDocumentVersion(product.id, doc.versions);
      if (!resolvedVersion) continue;

      paths.push({
        params: { version: product.id, slug: doc.slug },
        props: {
          productVersion: product.id,
          documentVersion: resolvedVersion,
          slug: doc.slug,
          hasUkTranslation: doc.ukVersions.includes(resolvedVersion),
        },
      });
    }
  }

  return paths;
}

const { productVersion, documentVersion, slug, hasUkTranslation } = Astro.props;

const activeLang: 'en' | 'uk' =
  Astro.url.searchParams.get('lang') === 'uk' && hasUkTranslation ? 'uk' : 'en';

const enEntryId = buildEntryId(slug, documentVersion, 'en');
const enEntry = await getSqlcorEntry(enEntryId);

if (!enEntry) {
  throw new Error(`Document not found: ${enEntryId}`);
}

const ukEntryId = hasUkTranslation
  ? buildEntryId(slug, documentVersion, 'uk')
  : null;
const ukEntry = ukEntryId ? await getSqlcorEntry(ukEntryId) : null;

const { Content: ContentEn, headings } = await render(enEntry);
const ukRendered = ukEntry ? await render(ukEntry) : null;

const pageTitle = enEntry.data.title;
const pageDescription = enEntry.data.description ?? '';
const defaultActiveLang = activeLang;
---

<StarlightPage
  frontmatter={{
    title: pageTitle,
    description: pageDescription,
    tableOfContents: {
      minHeadingLevel: 2,
      maxHeadingLevel: 3,
    },
    pagefind: true,
  }}
  headings={headings}
>
  <!-- Pagefind indexes only this region (excludes nav, sidebar, TOC). -->
  <div data-pagefind-body>
    <VersionBanner productVersion={productVersion} slug={slug} />

    <div class="opuscor-page-title-row">
      <LanguageSwitcher
        productVersion={productVersion}
        slug={slug}
        hasUkTranslation={hasUkTranslation}
        activeLang={defaultActiveLang}
      />
    </div>

    <div data-opuscor-lang="en" hidden={defaultActiveLang !== 'en'}>
      <ContentEn />
      <DocFooter
        documentVersion={enEntry.data.document_version}
        productVersion={productVersion}
        lastUpdated={enEntry.data.last_updated}
      />
    </div>

    {ukRendered && ukEntry && (
      <div data-opuscor-lang="uk" data-pagefind-ignore hidden={defaultActiveLang !== 'uk'}>
        <ukRendered.Content />
        <DocFooter
          documentVersion={ukEntry.data.document_version}
          productVersion={productVersion}
          lastUpdated={ukEntry.data.last_updated}
        />
      </div>
    )}
  </div>
</StarlightPage>

{hasUkTranslation && (
  <script is:inline>
    (function () {
      if (new URLSearchParams(location.search).get('lang') !== 'uk') return;

      document.querySelectorAll('[data-opuscor-lang]').forEach(function (el) {
        el.hidden = el.getAttribute('data-opuscor-lang') !== 'uk';
      });

      document.documentElement.lang = 'uk';

      var tocHeading = document.getElementById('starlight__on-this-page');
      if (tocHeading) tocHeading.textContent = 'На цій сторінці';

      document.querySelectorAll('.pagination-links a[rel="prev"] span').forEach(function (el) {
        if (el.firstChild && el.firstChild.nodeType === 3) {
          el.firstChild.textContent = 'Назад';
        }
      });

      document.querySelectorAll('.pagination-links a[rel="next"] span').forEach(function (el) {
        if (el.firstChild && el.firstChild.nodeType === 3) {
          el.firstChild.textContent = 'Далі';
        }
      });
    })();
  </script>
)}

<style is:global>
  .opuscor-page-title-row {
    display: flex;
    justify-content: flex-end;
    margin: calc(-1 * var(--opuscor-s-4)) 0 var(--opuscor-s-6);
  }
</style>
