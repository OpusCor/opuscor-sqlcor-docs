---
/**
 * Version landing page.
 *
 * Renders inside Starlight's layout (so users see sidebar, top nav,
 * search) but with a custom landing hero and card grid of available
 * documents — instead of the standard document layout.
 */
import { Image } from 'astro:assets';
import { PRODUCT_VERSIONS } from '../../lib/product-versions';
import heroImage from '../../assets/hero.png';

import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import Hero from '../../components/Hero.astro';
import Card from '../../components/Card.astro';
import CardGrid from '../../components/CardGrid.astro';

export function getStaticPaths() {
  return PRODUCT_VERSIONS.map((v) => ({
    params: { version: v.id },
    props: { productVersion: v.id, productLabel: v.label },
  }));
}

const { productVersion, productLabel } = Astro.props;

const ICONS = {
  installation: 'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z',
  userGuide: 'M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2zM22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z',
  adminGuide: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  features: 'M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3',
  messages: 'M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z',
  shortcuts: 'M6 8h.01M10 8h.01M14 8h.01M18 8h.01M6 12h.01M10 12h.01M14 12h.01M18 12h.01M7 16h10',
  troubleshooting: 'M12 9v2m0 4h.01M5.07 19h13.86a2 2 0 0 0 1.75-2.97L13.69 3.97a2 2 0 0 0-3.38 0L3.32 16.03A2 2 0 0 0 5.07 19z',
};
---

<StarlightPage
  frontmatter={{
    title: `SQL Cor ${productLabel}`,
    description: 'Secure SQL Workbench for Creatio — documentation.',
    template: 'splash',
    pagefind: false,
  }}
>
  <div class="hero-container">
    <div class="hero-text">
      <Hero
        tagline={`SQL Cor · ${productLabel}`}
        title="Secure SQL Workbench"
        description="Direct database access for Creatio administrators — with role-based gates and a full audit trail."
      >
        <a slot="actions" class="opuscor-btn opuscor-btn--primary glow-border" href={`/${productVersion}/installation/`}>
          Get started →
        </a>
      </Hero>
    </div>
    <div class="hero-image">
      <Image src={heroImage} alt="SQL Cor interface" width={1600} height={900} loading="eager" />
    </div>
  </div>

  <h2 style="margin-top: var(--opuscor-s-12); margin-bottom: var(--opuscor-s-6);">
    Browse the documentation
  </h2>

  <CardGrid>
    <Card
      href={`/${productVersion}/installation/`}
      title="Installation"
      description="Get SQL Cor running in your Creatio instance."
      iconPath={ICONS.installation}
    />
    <Card
      href={`/${productVersion}/user-guide/`}
      title="User Guide"
      description="Every button, field, and behavior explained."
      iconPath={ICONS.userGuide}
    />
    <Card
      href={`/${productVersion}/admin-guide/`}
      title="Admin Guide"
      description="Access control, blacklist, audit logs."
      iconPath={ICONS.adminGuide}
    />
    <Card
      href={`/${productVersion}/reference/features/`}
      title="Feature Reference"
      description="Quick lookup of every UI element."
      iconPath={ICONS.features}
    />
    <Card
      href={`/${productVersion}/reference/messages/`}
      title="Message Reference"
      description="Every system message and what it means."
      iconPath={ICONS.messages}
    />
    <Card
      href={`/${productVersion}/reference/shortcuts/`}
      title="Keyboard Shortcuts"
      description="All keyboard shortcuts in one place."
      iconPath={ICONS.shortcuts}
    />
    <Card
      href={`/${productVersion}/troubleshooting/`}
      title="Troubleshooting"
      description="Common problems and how to fix them."
      iconPath={ICONS.troubleshooting}
    />
  </CardGrid>
</StarlightPage>

<style>
  .hero-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--opuscor-s-10);
    align-items: center;
  }
  .hero-image :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--opuscor-r-4);
    border: 1px solid var(--opuscor-bdr);
    box-shadow: var(--opuscor-shadow-lg);
  }
  @media (max-width: 768px) {
    .hero-container {
      grid-template-columns: 1fr;
    }
  }
</style>

<style is:global>
  .opuscor-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--opuscor-s-2);
    padding: 0 var(--opuscor-s-5);
    height: 44px;
    border-radius: var(--opuscor-r-3);
    border: 1px solid var(--opuscor-bdr2);
    background: var(--opuscor-surf);
    color: var(--opuscor-tx);
    font-family: var(--opuscor-ff-sans);
    font-size: var(--opuscor-fz-base);
    font-weight: 500;
    cursor: pointer;
    transition: all var(--opuscor-t-fast);
    text-decoration: none;
    line-height: 1;
  }
  .opuscor-btn--primary {
    background: var(--opuscor-grad-brand);
    background-clip: padding-box;
    border-color: transparent;
    color: white;
    font-weight: 600;
  }
  .opuscor-btn--primary.glow-border {
    color: white;
    font-weight: 600;
  }
  .opuscor-btn--primary:hover {
    filter: brightness(1.08);
    color: white;
    text-decoration: none;
  }
</style>
